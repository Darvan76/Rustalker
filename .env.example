# Rustalker Discord Bot Configuration

# Discord Bot Token from developer portal
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: BattleMetrics Developer API Token (highly recommended to avoid rate limits)
BATTLEMETRICS_TOKEN=your_battlemetrics_token_here

# SQLite Database File Path (default is rustalker.db)
DATABASE_PATH=rustalker.db

# ─────────────────────────────────────────────────────────────────────────────
# Rust+ Integration (NO variables de entorno necesarias)
# ─────────────────────────────────────────────────────────────────────────────
# La integración con Rust+ se configura directamente desde Discord usando:
#   /rustplus pair ip:<IP> port:<PUERTO> steam_id:<TU_STEAM_ID> player_token:<TOKEN>
#
# Para obtener tu player_token:
#   1. Empareja un servidor en la app oficial de Rust+ en tu móvil
#   2. Usa una herramienta como rustplus.py companion o la extensión de navegador
#      de la comunidad para capturar el token de emparejamiento.
#   3. El puerto Companion por defecto es 28082 (diferente al puerto del juego)
# ─────────────────────────────────────────────────────────────────────────────
